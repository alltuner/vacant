{
  "name": "@alltuner/vacant",
  "version": "0.4.7",
  "description": "Fast domain availability checker — asks authoritative TLD nameservers directly instead of WHOIS.",
  "license": "MIT",
  "author": "David Poblador i Garcia <david@poblador.com>",
  "homepage": "https://github.com/alltuner/vacant",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alltuner/vacant.git"
  },
  "bugs": {
    "url": "https://github.com/alltuner/vacant/issues"
  },
  "keywords": [
    "domain",
    "availability",
    "dns",
    "registrar",
    "tld",
    "napi-rs"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "vacant": "./dist/bin/vacant.cjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "index.cjs",
    "index.d.ts",
    "vacant/rules.toml"
  ],
  "engines": {
    "node": ">=18"
  },
  "napi": {
    "binaryName": "vacant",
    "packageName": "@alltuner/vacant",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu"
    ]
  },
  "scripts": {
    "artifacts": "napi artifacts --output-dir .",
    "build": "tsup",
    "build:napi": "napi build --release --platform --manifest-path ../crates/vacant-js/Cargo.toml --output-dir . --package-json-path ./package.json --js index.cjs",
    "build:napi:debug": "napi build --platform --manifest-path ../crates/vacant-js/Cargo.toml --output-dir . --package-json-path ./package.json --js index.cjs",
    "test": "node --test tests/*.test.mjs",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.4.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^6.0.0"
  },
  "optionalDependencies": {
    "@alltuner/vacant-darwin-arm64": "0.4.0",
    "@alltuner/vacant-darwin-x64": "0.4.0",
    "@alltuner/vacant-linux-arm64-gnu": "0.4.0",
    "@alltuner/vacant-linux-x64-gnu": "0.4.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public",
    "provenance": true
  }
}
